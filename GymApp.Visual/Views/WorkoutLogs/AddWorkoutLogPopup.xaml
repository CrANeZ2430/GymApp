<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             x:Class="GymApp.Visual.Views.WorkoutLogs.AddWorkoutLogPopup"
             x:DataType="viewmodel:WorkoutLogs.AddWorkoutLogViewModel"
             BackgroundColor="Transparent"
             Background="Transparent"
             Margin="0"
             Padding="0"
             CanBeDismissedByTappingOutsideOfPopup="True">
    
    <Border Stroke="{StaticResource Primary}" 
            StrokeThickness="2"
            StrokeShape="RoundRectangle 20" 
            BackgroundColor="{StaticResource Gray900}"
            HorizontalOptions="Center"
            VerticalOptions="Center">

        <VerticalStackLayout Padding="24" Spacing="20" WidthRequest="320">

            <Label Text="Log Set" FontSize="22" FontAttributes="Bold" TextColor="White" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="WEIGHT (KG)" FontSize="10" TextColor="{StaticResource PrimaryDark}" Margin="0,0,0,5"/>
                    <Entry Keyboard="Numeric" BackgroundColor="#2C2C2E" TextColor="White" HeightRequest="50" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="REPS" FontSize="10" TextColor="{StaticResource PrimaryDark}" Margin="0,0,0,5"/>
                    <Entry Keyboard="Numeric" BackgroundColor="#2C2C2E" TextColor="White" HeightRequest="50" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Button Text="SAVE SET"/>

            <Button Text="Close"
            Command="{Binding CloseAddWorkoutLogPopupCommand}"/>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>