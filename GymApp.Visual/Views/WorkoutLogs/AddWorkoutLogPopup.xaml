<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             x:Class="GymApp.Visual.Views.WorkoutLogs.AddWorkoutLogPopup"
             x:DataType="viewmodel:WorkoutLogs.AddWorkoutLogViewModel"
             BackgroundColor="Transparent"
             Background="Transparent"
             Margin="0"
             Padding="0">

    <Border Stroke="{StaticResource Primary}" 
            StrokeThickness="2"
            StrokeShape="RoundRectangle 20" 
            BackgroundColor="{StaticResource Gray900}"
            HorizontalOptions="Center"
            VerticalOptions="Center">

        <VerticalStackLayout Padding="25" Spacing="20" WidthRequest="320">
            <Label Text="{Binding Title}" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   TextColor="White" />
            <Grid RowDefinitions="*,*,*,*,*,*" 
                  ColumnDefinitions="*,*" 
                  ColumnSpacing="15" 
                  RowSpacing="10">
                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                    <Label Text="Weight (kg)" 
                            FontSize="14" 
                            TextColor="{StaticResource PrimaryDark}"
                            FontAttributes="Bold"/>
                    <Entry Keyboard="Numeric" 
                            Text="{Binding Weight}" 
                            BackgroundColor="#2C2C2E" 
                            TextColor="White" 
                            HeightRequest="50" 
                            HorizontalTextAlignment="Center"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                    <Label Text="Sets" 
                            FontSize="14" 
                            TextColor="{StaticResource PrimaryDark}"
                            FontAttributes="Bold"/>
                    <Entry Keyboard="Numeric" 
                            Text="{Binding Sets}" 
                            BackgroundColor="#2C2C2E" 
                            TextColor="White" 
                            HeightRequest="50" 
                            HorizontalTextAlignment="Center"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="5">
                    <Label Text="Tracking type" 
                            FontSize="14" 
                            TextColor="{StaticResource PrimaryDark}"
                            FontAttributes="Bold"/>
                    <Picker SelectedItem="{Binding SelectedTrackingType}"
                            ItemsSource="{Binding TrackingTypes}"
                            BackgroundColor="#2C2C2E"
                            TextColor="White"
                            HeightRequest="50"
                            Title="Select Type"
                            TitleColor="Gray"/>
                </VerticalStackLayout>

                <VerticalStackLayout IsEnabled="{Binding IsRepsMode}" Grid.Row="2" Grid.ColumnSpan="2" Spacing="5">
                    <Label Text="Reps" 
                            FontSize="14" 
                            TextColor="{StaticResource PrimaryDark}"
                            FontAttributes="Bold"/>
                    <Entry Keyboard="Numeric" 
                            Text="{Binding Reps}" 
                            BackgroundColor="#2C2C2E" 
                            TextColor="White" 
                            HeightRequest="45" 
                            HorizontalTextAlignment="Center"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

                <VerticalStackLayout IsEnabled="{Binding IsDurationMode}" Grid.Row="3" Grid.ColumnSpan="2" Spacing="5">
                    <Label Text="Duration (sec)" 
                            FontSize="14" 
                            TextColor="{StaticResource PrimaryDark}"
                            FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*, Auto" 
                            BackgroundColor="#2C2C2E" 
                            Padding="15, 10"
                            HeightRequest="60">

                        <Label Grid.Column="0"
                                Text="{Binding Duration}" 
                                TextColor="White" 
                                FontSize="20" 
                                VerticalOptions="Center" />

                        <Stepper Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="600" 
                                    Increment="30"
                                    Value="{Binding Duration}"
                                    VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="4" Grid.ColumnSpan="2" Spacing="5">
                    <Label Text="Rest time (sec)" 
                            TextColor="{StaticResource PrimaryDark}" 
                            FontSize="14" 
                            FontAttributes="Bold"/>

                    <Grid ColumnDefinitions="*, Auto" 
                            BackgroundColor="#2C2C2E" 
                            Padding="15, 10"
                            HeightRequest="60">

                        <Label Grid.Column="0"
                                Text="{Binding RestTime}" 
                                TextColor="White" 
                                FontSize="20" 
                                VerticalOptions="Center" />

                        <Stepper Grid.Column="1" 
                                Minimum="0" 
                                Maximum="600" 
                                Increment="30"
                                Value="{Binding RestTime}"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <Button Grid.Row="5" 
                        Grid.Column="0"
                        Text="Save"/>

                <Button Grid.Row="5"
                        Grid.Column="1"
                        Text="Close"
                        Command="{Binding CloseAddWorkoutLogPopupCommand}"/>
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>