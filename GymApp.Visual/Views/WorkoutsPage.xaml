<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             xmlns:dto="clr-namespace:GymApp.Shared.Dtos;assembly=GymApp.Shared"
             x:Class="GymApp.Visual.Views.WorkoutsPage"
             x:DataType="viewmodel:Sessions.WorkoutsViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding GetSessionsCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid ColumnDefinitions="*,*"
          ColumnSpacing="5"
          RowDefinitions="*,Auto"
          RowSpacing="0"
          Padding="5">
        <CollectionView BackgroundColor="Transparent"
                        Grid.ColumnSpan="2"
                        ItemsSource="{Binding Sessions}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:SessionDto">
                    <Grid>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding .}"
                                                  Command="{Binding Source={RelativeSource 
                                                            AncestorType={x:Type viewmodel:Sessions.WorkoutsViewModel}},
                                                            Path=GoToSessionDetailsPageCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border BackgroundColor="{StaticResource Gray900}" 
                                Stroke="{StaticResource Gray600}"
                                StrokeThickness="1"
                                Padding="15" 
                                Margin="0,0,0,5"
                                StrokeShape="RoundRectangle 12">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Name}"
                                            TextColor="{StaticResource Secondary}"
                                            FontSize="18"
                                            FontAttributes="Bold"/>
                                    <Label Text="{Binding AppUserDto.UserName, StringFormat='by {0}'}"
                                            FontSize="12"
                                            TextColor="{StaticResource Gray400}"/>
                                    <Label Text="{Binding Date, StringFormat='{0:dd-MM-yyyy}'}"
                                            FontSize="12"
                                            TextColor="{StaticResource Gray500}"
                                            FontAttributes="Italic"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Grid.Column="0"
                Grid.Row="1"
                Text="Add Session"
                TextColor="White"
                Command="{Binding GoToAddSessionPageCommand}"/>
        <Button Grid.Column="1"
                Grid.Row="1"
                Text="Delete Session"
                TextColor="White"/>
    </Grid>
</ContentPage>