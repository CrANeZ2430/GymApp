<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             xmlns:view="clr-namespace:GymApp.Visual.Views"
             xmlns:dto="clr-namespace:GymApp.Shared.Dtos;assembly=GymApp.Shared"
             x:Class="GymApp.Visual.Views.Sessions.SessionDetailsPage"
             x:DataType="viewmodel:Sessions.SessionDetailsViewModel"
             Title="{Binding Title}">
    <Grid RowDefinitions="Auto, *, *, Auto" Padding="20" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" Spacing="5">  
            <Label Text="{Binding Session.Name}" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource PrimaryDark}"/>
            <Label Text="{Binding Session.Date, StringFormat='{0:dd-MM-yyyy}'}"/>
        </VerticalStackLayout>

        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            <Label Grid.Row="0" 
                   Text="Added exercises" 
                   FontSize="12" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource PrimaryDark}" 
                   Margin="0,0,0,5"/>

            <Border Grid.Row="1" 
                    Stroke="{StaticResource Gray600}" 
                    BackgroundColor="#1C1C1E" 
                    StrokeShape="RoundRectangle 12" 
                    Padding="5">
                <CollectionView ItemsSource="{Binding WorkoutLogs}" 
                                EmptyView="No logs added yet.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:WorkoutLogDto">
                            <Grid ColumnDefinitions="*, Auto" Padding="10">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Exercise.Name}" 
                                           FontAttributes="Bold" 
                                           TextColor="White"/>
                                    <Label Text="{Binding Weight, StringFormat='{0} kg'}" 
                                           FontSize="12" 
                                           TextColor="{StaticResource Gray400}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding Reps, StringFormat='Sets: {0}'}" 
                                       VerticalOptions="Center" 
                                       TextColor="{StaticResource Secondary}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto, *">
            <Label Grid.Row="0" 
                   Text="Available exercises" 
                   FontSize="12" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource PrimaryDark}" 
                   Margin="0,0,0,5"/>

            <Border Grid.Row="1" 
                    Stroke="{StaticResource Gray600}" 
                    BackgroundColor="#1C1C1E" 
                    StrokeShape="RoundRectangle 12" 
                    Padding="5">
                <CollectionView ItemsSource="{Binding Exercises}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:ExerciseDto">
                            <Grid ColumnDefinitions="*, Auto" Padding="10">
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="White"/>
                                    <Label Text="{Binding MuscleGroups}" FontSize="11" TextColor="{StaticResource Gray500}"/>
                                    <Label Text="{Binding Equipment}" FontSize="11" TextColor="{StaticResource Gray500}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="1" 
                                        Text="+"
                                        TextColor="White"
                                        Command="{Binding Source={RelativeSource 
                                    AncestorType={x:Type viewmodel:Sessions.SessionDetailsViewModel}}, 
                                    Path=ShowAddWorkoutLogPopupCommand}" 
                                        CommandParameter="{Binding .}" 
                                        WidthRequest="40" 
                                        HeightRequest="40" 
                                        CornerRadius="20" 
                                        Padding="0"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </Grid>

        <Button Grid.Row="3" 
                Text="Load Exercises" 
                TextColor="White"
                Command="{Binding GetExercisesCommand}" 
                VerticalOptions="End"/>

    </Grid>
</ContentPage>