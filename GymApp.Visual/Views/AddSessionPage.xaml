<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmode="clr-namespace:GymApp.Visual.ViewModels"
             x:Class="GymApp.Visual.Views.AddSessionPage"
             x:DataType="viewmode:Sessions.AddSessionViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Name" FontAttributes="Bold"/>
            <Entry Text="{Binding Name}"/>

            <Label Text="Date" FontAttributes="Bold"/>
            <DatePicker Date="{Binding Date}"
                        MaximumDate="12/31/2040"
                        MinimumDate="04/01/2026"
                        BackgroundColor="Transparent"/>

            <Label Text="Note" FontAttributes="Bold"/>
            <Entry Text="{Binding Note}"/>

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <CheckBox IsChecked="{Binding IsDefault}" />
                <Label Text="Is Default?" 
                       VerticalOptions="Center"
                       FontAttributes="Bold"/>
            </HorizontalStackLayout>

            <Button Text="Add Session"
                    TextColor="White"
                    Command="{Binding AddSessionCommand}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>