<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             xmlns:dto="clr-namespace:GymApp.Shared.Dtos;assembly=GymApp.Shared"
             x:Class="GymApp.Visual.Views.Exercises.ExercisesPage"
             x:DataType="viewmodel:Exercises.ExercisesViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh" 
                     Command="{Binding GetExercisesCommand}" />
    </ContentPage.ToolbarItems>

    <Grid ColumnDefinitions="*,*"
          ColumnSpacing="5"
          RowDefinitions="*,Auto"
          RowSpacing="0"
          Padding="5">
        <CollectionView BackgroundColor="Transparent"
                        Grid.ColumnSpan="2"
                        ItemsSource="{Binding Exercises}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:ExerciseDto">
                    <Border BackgroundColor="{StaticResource Gray900}" 
                            Stroke="{StaticResource Gray600}"
                            StrokeThickness="1"
                            Padding="15" 
                            Margin="0,0,0,5"
                            StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Name}"
                                        TextColor="{StaticResource Secondary}"
                                        FontSize="18"
                                        FontAttributes="Bold"/>
                                <Label Text="{Binding MuscleGroups}"
                                        FontSize="12"
                                        TextColor="{StaticResource Gray400}"/>
                                <Label Text="{Binding Equipment}"
                                        FontSize="12"
                                        TextColor="{StaticResource Gray500}"
                                        FontAttributes="Italic"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Grid.Column="0"
                Grid.Row="1"
                Text="Add Exercise"
                TextColor="White"
                Command="{Binding GoToAddExercisePageCommand}"/>
        <Button Grid.Column="1"
                Grid.Row="1"
                Text="Delete Exercises"
                TextColor="White"/>
    </Grid>

</ContentPage>
