<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:GymApp.Shared.Models.Exercises.Models;assembly=GymApp.Shared"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             x:Class="GymApp.Visual.View.AddExercisePage"
             x:DataType="viewmodel:AddExerciseViewModel"
             Title="AddExercisesPage">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="Name" FontAttributes="Bold"/>
            <Entry Text="{Binding Name}" Placeholder="e.g., Bench Press"/>

            <Label Text="Equipment" FontAttributes="Bold" />
            <Picker SelectedItem="{Binding Equipment}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type model:Equipment}">
                        <x:Static Member="model:Equipment.None"/>
                        <x:Static Member="model:Equipment.Barbell"/>
                        <x:Static Member="model:Equipment.Dumbbell"/>
                        <x:Static Member="model:Equipment.Machine"/>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label Text="Target Muscles" FontAttributes="Bold"/>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding FlagOptions}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewmodel:FlagOption">
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding IsSelected}" />
                            <Label Text="{Binding Name}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="Add Exercise"
                    TextColor="White"
                    Command="{Binding AddExerciseCommand}"/>
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>