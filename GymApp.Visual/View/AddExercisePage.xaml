<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             x:Class="GymApp.Visual.View.AddExercisePage"
             x:DataType="viewmodel:AddExerciseViewModel"
             Title="AddExercisesPage">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="Name" FontAttributes="Bold" />
            <Entry Text="{Binding ExTitle}" Placeholder="e.g., Bench Press" />

            <Label Text="Equipment" FontAttributes="Bold" />
            <Picker SelectedItem="{Binding Equipment}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>None</x:String>
                        <x:String>Barbell</x:String>
                        <x:String>Dumbbell</x:String>
                        <x:String>Machine</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label Text="Target Muscles" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding MuscleGroups}" />
                <Label Text="Chest" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button Text="Save" 
                    Margin="0,20" 
                    Command="{Binding AddExerciseCommand}"/>

        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>