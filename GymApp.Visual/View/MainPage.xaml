<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:GymApp.Visual.ViewModels"
             xmlns:dto="clr-namespace:GymApp.Shared.Dtos;assembly=GymApp.Shared"
             x:Class="GymApp.Visual.View.MainPage"
             Title="{Binding Title}"
             x:DataType="viewmodel:ExercisesViewModel">

    <Grid ColumnDefinitions="*,*"
          ColumnSpacing="5"
          RowDefinitions="*,Auto"
          RowSpacing="0"
          Padding="5">
        <CollectionView BackgroundColor="Transparent"
                        Grid.ColumnSpan="2"
                        ItemsSource="{Binding Exercises}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:ExerciseDto">
                    <Grid>
                        <Border HeightRequest="125">
                            <VerticalStackLayout>
                                <Label Text="{Binding Title}"/>
                                <Label Text="{Binding MuscleGroups}"/>
                                <Label Text="{Binding Equipment}"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Grid.Column="0"
                Grid.Row="1"
                Text="Get Exercises"
                TextColor="White"
                Command="{Binding GetExercisesCommand}"/>
        <Button Grid.Column="1"
                Grid.Row="1"
                Text="Add Exercise"
                TextColor="White"/>
    </Grid>

</ContentPage>
